# ══════════════════════════════════════════════════════════════════
#  VoxPoll AI — Environment Variables
#  cp .env.example .env   then fill in real values
#  NEVER commit .env to git
# ══════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════════
# TELEPHONY_PROVIDER — switch between providers
#   twilio  = US/global number (default for testing)
#   plivo   = Indian +91 number (recommended, no KYC wait)
#   exotel  = Indian number (best for production, requires KYC)
# ══════════════════════════════════════════════════════════════════
TELEPHONY_PROVIDER=twilio

# ── Plivo (recommended for Indian caller ID, no KYC needed) ─────
# 1. Sign up free at plivo.com
# 2. Buy an Indian +91 number (Phone Numbers → Buy)  ~$0.80/month
# 3. console.plivo.com → Overview → copy Auth ID & Auth Token
# Contacts will see your +91 number — no international call anxiety
PLIVO_AUTH_ID=MAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLIVO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLIVO_CALLER_ID=+91XXXXXXXXXX

# ── 1. Exotel — Telephony ──────────────────────────────────────────
# my.exotel.com → Settings → API settings page
#
# EXOTEL_SID       = Account SID  (e.g. home6305)
# EXOTEL_API_KEY   = API Key shown on the API settings page
#                    Singapore/newer accounts: DIFFERENT from SID
#                    Older accounts: leave blank (SID is used)
# EXOTEL_TOKEN     = API Token (48-char string on the API settings page)
# EXOTEL_CALLER_ID = Your virtual number with leading 0 (e.g. 09513886363)
# EXOTEL_SUBDOMAIN = API hostname:
#                    Singapore → api.exotel.com
#                    Mumbai    → api.in.exotel.com
EXOTEL_SID=home6305
EXOTEL_API_KEY=your_api_key_from_settings_page
EXOTEL_TOKEN=your_api_token_48_chars
EXOTEL_CALLER_ID=09513886363
EXOTEL_SUBDOMAIN=api.exotel.com

# ── 2. ElevenLabs — Voice Generation (Tamil TTS) ───────────────────
# elevenlabs.io → Profile → API Key
ELEVENLABS_KEY=your_elevenlabs_api_key
# Voice ID — recommended for Tamil:
#   pNInz6obpgDQGcFmaJgB  → Adam  (Male, clear)
#   EXAVITQu4vr4xnSDxMaL  → Bella (Female, warm)
#   21m00Tcm4TlvDq8ikWAM  → Rachel (Female, professional)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── 3. Whisper — Speech-to-Text ────────────────────────────────────
# Option A: OpenAI Whisper (paid, ~$0.006/min)
# platform.openai.com/settings/billing → add credits
WHISPER_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: Groq Whisper (FREE, same quality, faster)
# Sign up free at console.groq.com → API Keys → Create key
# If GROQ_KEY is set, it takes priority over WHISPER_KEY
GROQ_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 4. AI Conversation + Sentiment (OpenRouter — FREE) ──────────────
# Sign up free at openrouter.ai → Keys → Create key (no billing needed)
# Free models: google/gemma-3-27b-it:free  (recommended)
#              mistralai/mistral-7b-instruct:free  (fallback)
# OPENROUTER_KEY takes priority over GEMINI_KEY if both are set.
OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Legacy Gemini key (still works if you have one — OpenRouter is preferred)
GEMINI_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 5. Firestore (Google Cloud) ────────────────────────────────────
# LOCAL DEV:  Place your service account JSON file at:
#             backend/firebase-service-account.json
#             (download from Firebase Console → Project Settings → Service Accounts)
#
# CLOUD RUN:  base64-encode the JSON and paste here:
#             base64 -i firebase-service-account.json | tr -d '\n'
# FIREBASE_SERVICE_ACCOUNT=<base64-encoded-json>
#
# OR use Workload Identity on Cloud Run — no key needed at all.


# ── Telephony Provider ─────────────────────────────────────────────
# Switch between Exotel (production) and Twilio (testing)
# Set to "twilio" while Exotel KYC is pending
TELEPHONY_PROVIDER=exotel

# ── Twilio (use while waiting for Exotel KYC) ──────────────────────
# Sign up free at twilio.com — no KYC needed
# Console → Account Info → Account SID + Auth Token
# Get a trial number: twilio.com/console/phone-numbers
# Twilio trial: can only call verified numbers — verify yours at:
# twilio.com/console/phone-numbers/verified
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_CALLER_ID=+1xxxxxxxxxx

# ── Pre-call SMS (strongly recommended when using a US/international caller ID) ──
# Sends a Tamil+English SMS to each contact 15s before the AI call
# so they don't ignore an unknown international number.
#
# Requirements: Twilio account with SMS enabled (same SID/TOKEN)
# TWILIO_SMS_FROM — use your Twilio number OR a Messaging Service SID (MGxxx)
# If left blank, TWILIO_CALLER_ID is used as the SMS sender.
#
# Set to "true" to enable, "false" (default) to disable.
SEND_PRECALL_SMS=false
TWILIO_SMS_FROM=+13045073297   # same as TWILIO_CALLER_ID, or a dedicated SMS number

# ── Testing helpers ────────────────────────────────────────────────
# FORCE_SAY=true  → skip ElevenLabs <Play>, use Twilio <Say> instead
# Useful to test call flow without audio fetch issues during local dev
# Remove or set to false for production
FORCE_SAY=false

PORT=3001

# Backend public URL — Exotel webhooks + ElevenLabs audio served here
# Example: https://api.yourdomain.com  OR  https://voxpoll-xyz.run.app
PUBLIC_URL=https://api.yourdomain.com

# Frontend URL (for CORS)
FRONTEND_URL=https://survey.yourdomain.com
